#!/usr/bin/env bash
set -u
set -o pipefail

mkdir -p compressed originals-compressed originals-kept-as-is

find . -maxdepth 1 -type f \( \
  -iname "*.mp4" -o \
  -iname "*.mov" -o \
  -iname "*.3gp" -o \
  -iname "*.gif" \
\) -print0 |
sort -z |
while IFS= read -r -d '' fichier; do
  base="$(basename "$fichier")"
  nom="${base%.*}"

  largeur="$(ffprobe -v error -select_streams v:0 -show_entries stream=width -of default=noprint_wrappers=1:nokey=1 "$fichier" | head -n 1)"
  hauteur="$(ffprobe -v error -select_streams v:0 -show_entries stream=height -of default=noprint_wrappers=1:nokey=1 "$fichier" | head -n 1)"
  fps_fraction="$(ffprobe -v error -select_streams v:0 -show_entries stream=avg_frame_rate -of default=noprint_wrappers=1:nokey=1 "$fichier" | head -n 1)"

  fps="$(awk -v valeur="$fps_fraction" 'BEGIN { split(valeur,n,"/"); if (n[2] > 0) printf "%.3f", n[1]/n[2]; else print "0" }')"

  if [[ ! "$largeur" =~ ^[0-9]+$ || ! "$hauteur" =~ ^[0-9]+$ || "$fps" == "0" ]]; then
    echo "Ignorée, informations illisibles : $base"
    continue
  fi

  resolution_conforme=0
  if (( largeur <= 1920 && hauteur <= 1080 )); then
    resolution_conforme=1
  elif (( largeur <= 1080 && hauteur <= 1920 )); then
    resolution_conforme=1
  fi

  fps_superieur_30="$(awk -v fps="$fps" 'BEGIN { print (fps > 30.01) ? 1 : 0 }')"

  if (( resolution_conforme == 1 && fps_superieur_30 == 0 )); then
    echo "Déplacée sans compression : $base (${largeur}x${hauteur}, ${fps} fps)"
    mv -n -- "$fichier" "originals-kept-as-is/$base"
    continue
  fi

  sortie="compressed/${nom}.MP4"
  temporaire="compressed/.${nom}.part.MP4"

  if find compressed -maxdepth 1 -type f -name "${nom}.*" | grep -q .; then
    echo "Déjà compressée, original déplacé : $base"
    mv -n -- "$fichier" "originals-compressed/$base"
    continue
  fi

  rm -f -- "$temporaire"

  if (( fps_superieur_30 == 1 )); then
    fps_final="30"
  else
    fps_final="$fps"
  fi

  filtre="fps=${fps_final},scale='if(gt(iw,ih),min(iw,1920),min(iw,1080))':'if(gt(iw,ih),min(ih,1080),min(ih,1920))':force_original_aspect_ratio=decrease:force_divisible_by=2"

  echo "Compression : $base (${largeur}x${hauteur}, ${fps} fps → max 1080p, ${fps_final} fps)"

  if ffmpeg -hide_banner -v warning -nostdin -n \
    -i "$fichier" \
    -map 0:v:0 \
    -map '0:a?' \
    -map_metadata 0 \
    -vf "$filtre" \
    -c:v libx264 \
    -preset slow \
    -crf 20 \
    -profile:v high \
    -level:v 4.1 \
    -pix_fmt yuv420p \
    -c:a aac \
    -b:a 160k \
    -movflags +faststart \
    "$temporaire"
  then
    mv -- "$temporaire" "$sortie"
    mv -n -- "$fichier" "originals-compressed/$base"
    echo "Terminée : $sortie"
  else
    echo "Échec : $base"
    rm -f -- "$temporaire"
  fi
done
