#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "$0")/../.." && pwd)"

if ! command -v zenity >/dev/null 2>&1; then
  pkexec apt-get update
  pkexec apt-get install -y zenity
fi

zenity --question \
  --title="Install Photography Archiving Workflow" \
  --text="This will install required Ubuntu packages and copy the workflow tools to ~/.local/bin.\n\nContinue?" || exit 0

pkexec apt-get update

pkexec apt-get install -y \
  exiftool \
  ffmpeg \
  dcraw \
  jpeginfo \
  pngcheck \
  webp \
  libheif-examples \
  zenity

mkdir -p "$HOME/.local/bin"

for file in "$repo_root/scripts/"*; do
  [ -f "$file" ] || continue
  install -m 755 "$file" "$HOME/.local/bin/$(basename "$file")"
done

install -m 755 "$repo_root/gui/wrappers/normalize-media-gui" "$HOME/.local/bin/normalize-media-gui"
install -m 755 "$repo_root/gui/wrappers/sanity-check-gui" "$HOME/.local/bin/sanity-check-gui"
install -m 755 "$repo_root/gui/wrappers/uninstall-gui" "$HOME/.local/bin/uninstall-photography-archiving-workflow"

mkdir -p "$HOME/.local/share/applications"

cat > "$HOME/.local/share/applications/normalize-media.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Normalize Media
Comment=Normalize metadata and rename media files in a selected folder
Exec=$HOME/.local/bin/normalize-media-gui
Terminal=false
Categories=Graphics;Photography;Utility;
EOF

cat > "$HOME/.local/share/applications/media-sanity-check.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Media Sanity Check
Comment=Check whether media files are readable
Exec=$HOME/.local/bin/sanity-check-gui
Terminal=false
Categories=Graphics;Photography;Utility;
EOF

cat > "$HOME/.local/share/applications/uninstall-photography-archiving-workflow.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Uninstall Photography Archiving Workflow
Comment=Remove installed workflow tools and desktop launchers
Exec=$HOME/.local/bin/uninstall-photography-archiving-workflow
Terminal=false
Categories=Utility;
EOF

chmod 755 "$HOME/.local/share/applications/normalize-media.desktop"
chmod 755 "$HOME/.local/share/applications/media-sanity-check.desktop"
chmod 755 "$HOME/.local/share/applications/uninstall-photography-archiving-workflow.desktop"

if command -v update-desktop-database >/dev/null 2>&1; then
  update-desktop-database "$HOME/.local/share/applications" >/dev/null 2>&1 || true
fi

zenity --info \
  --title="Installed" \
  --text="Photography Archiving Workflow is installed.\n\nYou can now launch:\n\n- Normalize Media\n- Media Sanity Check\n\nfrom your applications menu."
