#!/usr/bin/env bash
set -euo pipefail

dir="$(zenity --file-selection --directory --title="Select media folder")" || exit 0

prefix="$(zenity --entry \
  --title="Filename prefix" \
  --text="Enter filename prefix:" \
  --entry-text="CV")" || exit 0

if [ -z "$prefix" ]; then
  zenity --error --text="Prefix cannot be empty."
  exit 1
fi

zenity --question \
  --title="Confirm normalization" \
  --text="Normalize media files in:\n\n$dir\n\nPrefix:\n$prefix\n\nThis may rename files and update metadata." || exit 0

log="/tmp/media-normalize-gui_$(date +%y%m%d%H%M%S).log"

if (
  cd "$dir"
  media-normalize "$prefix"
) >"$log" 2>&1; then
  zenity --info \
    --title="Done" \
    --text="Media normalization completed.\n\nLog:\n$log"
else
  zenity --error \
    --title="Failed" \
    --text="Media normalization failed.\n\nLog:\n$log"
  exit 1
fi
