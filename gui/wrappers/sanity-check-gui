#!/usr/bin/env bash
set -euo pipefail

dir="$(zenity --file-selection --directory --title="Select media folder")" || exit 0

mode="$(zenity --list \
  --title="Sanity check mode" \
  --text="Choose check strength:" \
  --column="Mode" \
  fast normal deep)" || exit 0

if [ "$mode" = "deep" ]; then
  zenity --question \
    --title="Deep check warning" \
    --text="Deep mode fully decodes videos and can take a long time.\n\nContinue?" || exit 0
fi

log="/tmp/media-sanity-check-gui_$(date +%y%m%d%H%M%S).log"

if (
  cd "$dir"
  media-sanity-check "$mode"
) >"$log" 2>&1; then
  zenity --info \
    --title="Done" \
    --text="Media sanity check completed.\n\nMode: $mode\nLog:\n$log"
else
  zenity --error \
    --title="Failed" \
    --text="Media sanity check failed.\n\nMode: $mode\nLog:\n$log"
  exit 1
fi
